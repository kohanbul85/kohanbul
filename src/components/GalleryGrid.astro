---
interface Props {
  images: string[];
  alt?: string;
}

const { images, alt = '' } = Astro.props;
---

{images.length > 0 && (
  <div class="gallery">
    {images.map((src, i) => (
      <div class="gallery__item">
        <img src={src} alt={`${alt} 스틸컷 ${i + 1}`} loading="lazy" />
      </div>
    ))}
  </div>
)}

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
  }

  .gallery__item {
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: #e8e6e0;
  }

  .gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.25s;
  }
  .gallery__item img:hover { opacity: 0.88; }

  @media (min-width: 768px) {
    .gallery { grid-template-columns: repeat(3, 1fr); }
  }
</style>
