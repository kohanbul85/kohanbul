---
interface Props {
  slug: string;
  title_ko: string;
  title_en: string;
  year: number;
  type: string;
  runtime_min?: number;
  thumbnail: string;
  excerpt?: string;
}

const { slug, title_ko, title_en, year, type, runtime_min, thumbnail, excerpt } = Astro.props;
---

<a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/works/${slug}`} class="work-card">
  <div class="work-card__image">
    <img src={thumbnail} alt={title_ko} loading="lazy" />
  </div>
  <div class="work-card__info">
    <p class="work-card__meta">
      {year}
      {type && <span class="sep">·</span>}
      {type}
      {runtime_min && <span class="sep">·</span>}
      {runtime_min && `${runtime_min}분`}
    </p>
    <h2 class="work-card__title-ko">{title_ko}</h2>
    <p class="work-card__title-en">{title_en}</p>
    {excerpt && <p class="work-card__excerpt">{excerpt}</p>}
  </div>
</a>

<style>
  .work-card {
    display: block;
    text-decoration: none;
  }
  .work-card:hover { text-decoration: none; }
  .work-card:hover .work-card__image img {
    opacity: 0.88;
  }

  .work-card__image {
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: #e8e6e0;
    margin-bottom: 1.1rem;
  }
  .work-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.25s;
  }

  .work-card__meta {
    font-family: 'Noto Serif', serif;
    font-size: 0.75rem;
    color: #888;
    letter-spacing: 0.05em;
    margin-bottom: 0.4rem;
  }
  .sep { margin: 0 0.3em; }

  .work-card__title-ko {
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 0.2rem;
  }

  .work-card__title-en {
    font-family: 'Noto Serif', serif;
    font-size: 0.82rem;
    color: #666;
    font-style: italic;
    margin-bottom: 0.6rem;
  }

  .work-card__excerpt {
    font-size: 0.85rem;
    color: #555;
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
