---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const filmography = (await getCollection('filmography'))
  .sort((a, b) => a.data.order - b.data.order);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Filmography" description="고한벌 감독 필모그래피 전체 목록">
  <div class="container">
    <p class="page-title">Filmography</p>

    <table class="filmo-table">
      <thead>
        <tr>
          <th class="col-year">연도</th>
          <th class="col-title">작품</th>
          <th class="col-role">역할</th>
          <th class="col-type">유형</th>
        </tr>
      </thead>
      <tbody>
        {filmography.map(({ data: { year, title_ko, title_en, roles, role_detail, type, work_slug, link } }) => {
          const href = work_slug ? `${base}/works/${work_slug}` : (link ?? null);
          const isExternal = !work_slug && !!link;
          return (
            <tr
              class={href ? 'has-link' : undefined}
              data-href={href ?? undefined}
              data-external={isExternal ? 'true' : undefined}
            >
              <td class="col-year">{year}</td>
              <td class="col-title">
                <span class={`title-ko${href ? ' title-ko--linked' : ''}`}>
                  {title_ko}
                  {work_slug && <span class="link-icon" aria-hidden="true">→</span>}
                  {isExternal && <span class="link-icon" aria-hidden="true">↗</span>}
                </span>
                {title_en && <span class="title-en">{title_en}</span>}
              </td>
              <td class="col-role">
                {roles.join(', ')}
                {role_detail && <span class="role-detail">({role_detail})</span>}
              </td>
              <td class="col-type">{type || '—'}</td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
</BaseLayout>

<style>
  .filmo-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  thead th {
    font-family: 'Noto Serif', serif;
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #888;
    text-align: left;
    padding: 0 0 0.8rem;
    border-bottom: 1px solid #ddd;
  }

  tbody tr {
    border-bottom: 1px solid #eee;
  }
  tbody tr:hover { background: #f7f5f0; }

  tbody td {
    padding: 0.9rem 0.5rem 0.9rem 0;
    vertical-align: top;
  }

  .col-year {
    font-family: 'Noto Serif', serif;
    font-size: 0.85rem;
    color: #666;
    white-space: nowrap;
    padding-right: 1.5rem;
    width: 4rem;
  }

  .col-title { padding-right: 2rem; }

  .title-ko { display: inline-flex; align-items: baseline; gap: 0.3em; }

  .title-ko--linked {
    text-decoration: underline;
    text-decoration-color: #ccc;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: text-decoration-color 0.15s;
  }

  .link-icon {
    font-size: 0.72rem;
    color: #aaa;
    transition: color 0.15s;
    flex-shrink: 0;
    font-style: normal;
    font-family: 'Noto Serif', serif;
  }

  tr.has-link { cursor: pointer; }
  tr.has-link:hover .title-ko--linked { text-decoration-color: #333; }
  tr.has-link:hover .link-icon { color: #333; }

  .title-en {
    display: block;
    font-family: 'Noto Serif', serif;
    font-size: 0.78rem;
    color: #888;
    font-style: italic;
    margin-top: 0.15rem;
  }

  .col-role { color: #444; padding-right: 2rem; }
  .role-detail {
    font-size: 0.8rem;
    color: #888;
    margin-left: 0.3em;
  }

  .col-type {
    font-family: 'Noto Serif', serif;
    font-size: 0.82rem;
    color: #888;
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .col-type { display: none; }
    .col-year { padding-right: 1rem; }
  }
</style>

<script>
  document.querySelectorAll<HTMLTableRowElement>('tr[data-href]').forEach((row) => {
    row.addEventListener('click', () => {
      const href = row.dataset.href!;
      if (row.dataset.external === 'true') {
        window.open(href, '_blank', 'noopener,noreferrer');
      } else {
        window.location.href = href;
      }
    });
  });
</script>
