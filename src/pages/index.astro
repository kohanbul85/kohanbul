---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkCard from '../components/WorkCard.astro';

const featuredWorks = (await getCollection('works', ({ data }) =>
  data.is_featured && !data.draft
)).sort((a, b) => a.data.order - b.data.order);

const allWorks = await getCollection('works', ({ data }) => !data.draft);
const allAwards = allWorks
  .flatMap((w) =>
    w.data.awards.map((a) => ({ ...a, work_title: w.data.title_ko, work_slug: w.id.replace(/\.md$/, '') }))
  )
  .sort((a, b) => b.year - a.year)
  .slice(0, 3);

const [director] = await getCollection('director');
const { Content: BioContent } = await render(director);

function getExcerpt(body: string | undefined): string {
  if (!body) return '';
  const clean = body.replace(/^#+\s.+$/gm, '').replace(/\n+/g, ' ').trim();
  return clean.length > 100 ? clean.slice(0, 100) + '…' : clean;
}

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="KO HANBUL">
  <!-- Hero -->
  <section class="hero">
    <div class="hero__inner">
      <div class="hero__text">
        <h1 class="hero__name-en">KO HANBUL</h1>
        <p class="hero__name-ko">고한벌</p>
        <p class="hero__role">{director.data.primary_role} / {director.data.birth_year_display}</p>
        <div class="hero__bio">
          <BioContent />
        </div>
        <a href={`${base}/about`} class="hero__link">About →</a>
      </div>
      <div class="hero__profile">
        <img
          src={director.data.profile_image}
          alt={`${director.data.name_ko} 프로필`}
        />
      </div>
    </div>
  </section>

  <!-- Featured Works -->
  <section class="section">
    <div class="container">
      <p class="page-title">Works</p>
      <div class="home-works-grid">
        {featuredWorks.map((work) => (
          <WorkCard
            slug={work.id.replace(/\.md$/, '')}
            title_ko={work.data.title_ko}
            title_en={work.data.title_en}
            year={work.data.year}
            type={work.data.type}
            runtime_min={work.data.runtime_min}
            thumbnail={work.data.thumbnail}
            excerpt={getExcerpt(work.body)}
          />
        ))}
      </div>
      <div class="section__more">
        <a href={`${base}/works`}>모든 작품 보기 →</a>
      </div>
    </div>
  </section>

  <!-- Recent Awards -->
  {allAwards.length > 0 && (
    <section class="section section--alt">
      <div class="container">
        <p class="page-title">Awards &amp; Screenings</p>
        <ul class="home-awards">
          {allAwards.map(({ year, festival, award, work_title, work_slug }) => (
            <li class="home-awards__item">
              <span class="home-awards__year">{year}</span>
              <span class="home-awards__detail">
                <span class="home-awards__festival">{festival}</span>
                <span class="home-awards__award">{award}</span>
                <a href={`${base}/works/${work_slug}`} class="home-awards__work">{work_title}</a>
              </span>
            </li>
          ))}
        </ul>
        <div class="section__more">
          <a href={`${base}/awards`}>전체 수상 내역 →</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  /* ── HERO ── */
  .hero {
    padding: 5rem 2rem 4rem;
    max-width: 1040px;
    margin: 0 auto;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: start;
  }
  .hero__name-en {
    font-family: 'Noto Serif', serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 600;
    letter-spacing: 0.08em;
    line-height: 1;
    margin-bottom: 0.3rem;
  }
  .hero__name-ko {
    font-size: 1rem;
    color: #666;
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
  }
  .hero__role {
    font-family: 'Noto Serif', serif;
    font-size: 0.8rem;
    color: #999;
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
  }
  .hero__bio {
    font-size: 0.97rem;
    line-height: 1.9;
    color: #333;
    max-width: 560px;
    margin-bottom: 1.8rem;
  }
  .hero__bio :global(p) { margin: 0; }
  .hero__link {
    font-family: 'Noto Serif', serif;
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    color: #666;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
    text-decoration: none;
  }
  .hero__link:hover { color: #111; text-decoration: none; }
  .hero__profile {
    width: clamp(120px, 15vw, 200px);
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #e8e6e0;
    flex-shrink: 0;
  }
  .hero__profile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── SECTIONS ── */
  .section { padding: 0 0 5rem; }
  .section--alt { background: #f4f2ee; padding: 4rem 0; }

  .home-works-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: 2rem;
  }
  @media (min-width: 720px) {
    .home-works-grid { grid-template-columns: repeat(3, 1fr); gap: 2.5rem; }
  }

  .section__more {
    margin-top: 2rem;
  }
  .section__more a {
    font-family: 'Noto Serif', serif;
    font-size: 0.82rem;
    letter-spacing: 0.05em;
    color: #666;
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
  }
  .section__more a:hover { color: #111; text-decoration: none; }

  /* ── HOME AWARDS ── */
  .home-awards { list-style: none; }
  .home-awards__item {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: 1rem;
    padding: 0.7rem 0;
    border-bottom: 1px solid #ddd;
  }
  .home-awards__item:first-child { border-top: 1px solid #ddd; }
  .home-awards__year {
    font-family: 'Noto Serif', serif;
    font-size: 0.82rem;
    color: #888;
    padding-top: 0.1em;
  }
  .home-awards__detail { display: flex; flex-direction: column; gap: 0.1rem; }
  .home-awards__festival { font-size: 0.82rem; color: #666; }
  .home-awards__award { font-size: 0.9rem; font-weight: 600; }
  .home-awards__work {
    font-size: 0.78rem;
    color: #888;
    font-style: italic;
  }
  .home-awards__work:hover { color: #333; text-decoration: none; }

  /* ── MOBILE ── */
  @media (max-width: 640px) {
    .hero { padding: 3rem 1.25rem 2.5rem; }
    .hero__inner { grid-template-columns: 1fr; gap: 2rem; }
    .hero__profile { width: 120px; }
  }
</style>
