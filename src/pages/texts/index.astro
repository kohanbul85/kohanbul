---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const criticism = (await getCollection('criticism'))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function formatDate(dateStr: string) {
  const [y, m, d] = dateStr.split('-');
  return `${y}.${m}.${d}`;
}
---

<BaseLayout title="Texts" description="고한벌 영화에 대한 비평">
  <div class="container">
    <p class="page-title">Texts</p>

    <ul class="texts-list">
      {criticism.map(({ id, data: { title, date, author, source } }) => (
        <li class="texts-item">
          <span class="texts-date">{formatDate(date)}</span>
          <span class="texts-body">
            <a href={`${base}/texts/criticism/${id.replace(/\.md$/, '')}`} class="texts-title">{title}</a>
            <span class="texts-meta">{author}{source && ` · ${source}`}</span>
          </span>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>

<style>
  .texts-list { list-style: none; }

  .texts-item {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 1rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid #eee;
    align-items: start;
  }
  .texts-item:first-child { border-top: 1px solid #eee; }

  .texts-date {
    font-family: 'Noto Serif', serif;
    font-size: 0.78rem;
    color: #aaa;
    white-space: nowrap;
    padding-top: 0.1em;
  }

  .texts-body {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .texts-title {
    font-size: 0.9rem;
    color: #111;
  }
  .texts-title:hover { text-decoration: underline; text-underline-offset: 3px; }

  .texts-meta {
    font-family: 'Noto Serif', serif;
    font-size: 0.75rem;
    color: #999;
  }

  @media (max-width: 600px) {
    .texts-item { grid-template-columns: 5.5rem 1fr; gap: 0.75rem; }
  }
</style>
